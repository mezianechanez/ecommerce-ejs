<%- include('../partials/header', { title: 'Produits' }) %>

<div class="page-header">
    <div>
        <h2 class="page-title">Liste des produits</h2>
        <p class="page-subtitle">Gestion complète des produits enregistrés dans la base de données.</p>
    </div>

    <% if (user) { %>
        <div>
            <a href="/products/add" class="btn btn-primary">Ajouter un produit</a>
        </div>
    <% } %>
</div>

<div class="table-card">
    <% if (products.length === 0) { %>
        <p class="mb-0">Aucun produit disponible pour le moment.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <% if (user && user.role === 'admin') { %>
                            <th class="text-end">Actions</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(product) { %>
                        <tr>
                            <td><%= product.id %></td>
                            <td><strong><%= product.name %></strong></td>
                            <td><%= product.price %> $</td>

                            <% if (user && user.role === 'admin') { %>
                                <td class="text-end">
                                    <a href="/products/edit/<%= product.id %>" class="btn btn-warning btn-sm">Modifier</a>
                                    <form action="/products/delete/<%= product.id %>?_method=DELETE" method="POST" class="d-inline p-0 shadow-none border-0 bg-transparent" style="backdrop-filter: none;" onsubmit="return confirm('Voulez-vous vraiment supprimer ce produit ?');">
                                        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                    </form>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>