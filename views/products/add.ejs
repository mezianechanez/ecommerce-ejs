<%- include('../partials/header', { title: 'Ajouter un produit' }) %>

<h2 class="page-title">Ajouter un produit</h2>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/products/add" method="POST" enctype="multipart/form-data" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Nom du produit :</label>
                <input type="text" name="name" class="form-control" placeholder="Nom du produit">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Prix du produit :</label>
                <input type="number" step="0.01" name="price" class="form-control" placeholder="0.00">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Image du produit :</label>
                <input type="file" name="image" class="form-control" accept="image/*">
            </div>

            <button type="submit" class="btn btn-success">Ajouter</button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>