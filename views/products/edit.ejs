<%- include('../partials/header', { title: 'Modifier un produit' }) %>

<h2 class="page-title">Modifier un produit</h2>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/products/edit/<%= product.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Nom du produit :</label>
                <input type="text" name="name" class="form-control" value="<%= product.name %>">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Prix du produit :</label>
                <input type="number" step="0.01" name="price" class="form-control" value="<%= product.price %>">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Image du produit :</label>
                <% if (product.image) { %>
                    <div class="mb-2">
                        <img src="<%= product.image %>" alt="Image actuelle" style="width: 120px; height: 120px; object-fit: cover; border-radius: 8px;">
                        <br><small class="text-muted">Image actuelle</small>
                    </div>
                <% } %>
                <input type="file" name="image" class="form-control" accept="image/*">
                <small class="text-muted">Laissez vide pour garder l'image actuelle.</small>
            </div>

            <button type="submit" class="btn btn-warning">Modifier</button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>