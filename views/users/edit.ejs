<%- include('../partials/header', { title: 'Modifier un utilisateur' }) %>

<div class="page-header">
    <h2 class="page-title">Modifier l'Utilisateur</h2>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/users/edit/<%= user_edit.id %>?_method=PUT" method="POST" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Nom complet</label>
                <input type="text" name="name" class="form-control" required value="<%= user_edit.name %>">
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input type="email" name="email" class="form-control" required value="<%= user_edit.email %>">
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Nouveau Mot de passe (optionnel)</label>
                <input type="password" name="new_password" class="form-control" placeholder="Laissez vide pour conserver l'actuel">
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Rôle</label>
                <select name="role" class="form-select">
                    <option value="user" <%= user_edit.role === 'user' ? 'selected' : '' %>>Utilisateur</option>
                    <option value="admin" <%= user_edit.role === 'admin' ? 'selected' : '' %>>Administrateur</option>
                </select>
            </div>

            <hr class="my-4">
            
            <div class="d-flex justify-content-between">
                <a href="/users" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-dark-buy">Sauvegarder</button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
