<%- include('../partials/header', { title: 'Catégories' }) %>

<div class="page-header">
    <div>
        <h2 class="page-title">Liste des catégories</h2>
        <p class="page-subtitle">Gestion des catégories utilisées dans l'application.</p>
    </div>

    <% if (user) { %>
        <div>
            <a href="/categories/add" class="btn btn-primary">Ajouter une catégorie</a>
        </div>
    <% } %>
</div>

<div class="table-card">
    <% if (categories.length === 0) { %>
        <p class="mb-0">Aucune catégorie disponible pour le moment.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Nom</th>
                        <% if (user && user.role === 'admin') { %>
                            <th class="text-end">Actions</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% categories.forEach(function(category) { %>
                        <tr>
                            <td><%= category.id %></td>
                            <td>
                                <% if (category.image) { %>
                                    <img src="<%= category.image %>" alt="<%= category.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                <% } else { %>
                                    <span class="text-muted">—</span>
                                <% } %>
                            </td>
                            <td><strong><%= category.name %></strong></td>

                            <% if (user && user.role === 'admin') { %>
                                <td class="text-end">
                                    <a href="/categories/edit/<%= category.id %>" class="btn btn-warning btn-sm">Modifier</a>
                                    <form action="/categories/delete/<%= category.id %>?_method=DELETE" method="POST" class="d-inline p-0 shadow-none border-0 bg-transparent" style="backdrop-filter: none;" onsubmit="return confirm('Voulez-vous vraiment supprimer cette catégorie ?');">
                                        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                    </form>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>