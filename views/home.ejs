<%- include('partials/header', { title: 'Accueil' }) %>

<section class="hero-section">
    <div class="row align-items-center">
        <div class="col-lg-6 hero-text-area">
            <h1 class="hero-title">E-Commerce</h1>
            <p class="hero-text">
                Bienvenue sur notre plateforme e-commerce. <br/><br/>
                Cette application permet de gérer les produits, les catégories et les utilisateurs
                à travers une interface simple, moderne et sécurisée.
            </p>

            <div class="mt-4 d-flex gap-3 flex-wrap">
                <a href="/auth/login" class="btn btn-shop">Connexion</a>
                <a href="/products" class="btn btn-dark-buy">Voir les produits</a>
                <a href="/categories" class="btn btn-shop">Voir les catégories</a>
            </div>
            
            <div class="social-icons mt-5">
                <span>f</span>
                <span>▶</span>
                <span>y</span>
            </div>
        </div>

        <div class="col-lg-6 mt-4 mt-lg-0 text-center position-relative">
            <img src="/public/images/hero_illustration.png" alt="E-Commerce Illustration" class="img-fluid custom-hero-img">
        </div>
    </div>
</section>

<section class="mt-5 feature-glass-section pb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card glass">
                <h4>Produits</h4>
                <p>Afficher, ajouter, modifier et supprimer les produits enregistrés dans la base de données.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card glass">
                <h4>Catégories</h4>
                <p>Organiser les produits dans des catégories pour améliorer la structure de l’application.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card glass">
                <h4>Sécurité</h4>
                <p>Limiter les actions sensibles aux utilisateurs connectés grâce aux sessions.</p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>