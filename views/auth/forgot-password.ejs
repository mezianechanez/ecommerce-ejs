<%- include('../partials/header', { title: 'Mot de passe oublié' }) %>

<h2 class="page-title">Réinitialiser le mot de passe</h2>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/auth/forgot-password" method="POST" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Votre email :</label>
                <input type="email" name="email" class="form-control" placeholder="votre@email.com" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Nouveau mot de passe (min. 6 caractères) :</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Confirmer le nouveau mot de passe :</label>
                <input type="password" name="password_confirm" class="form-control" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-dark-buy">Réinitialiser</button>
            <div class="mt-3">
                <a href="/auth/login" class="text-decoration-none" style="color: #4a2d7a;">← Retour à la connexion</a>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
