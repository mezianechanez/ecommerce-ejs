<%- include('../partials/header', { title: 'Inscription' }) %>

<h2 class="page-title">Inscription</h2>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/auth/register" method="POST" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Nom :</label>
                <input type="text" name="name" class="form-control" placeholder="Votre nom">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Email :</label>
                <input type="email" name="email" class="form-control" placeholder="votre@email.com">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mot de passe (min. 6 caractères) :</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••">
            </div>

            <button type="submit" class="btn btn-dark-buy">S'inscrire</button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>