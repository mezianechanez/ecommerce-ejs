<%- include('../partials/header', { title: 'Connexion' }) %>

<h2 class="page-title">Connexion</h2>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(e => { %>
                <li><%= e.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <form action="/auth/login" method="POST" class="glass">
            <div class="mb-3">
                <label class="form-label fw-bold">Email :</label>
                <input type="email" name="email" class="form-control" placeholder="votre@email.com">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mot de passe :</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••">
            </div>

            <button type="submit" class="btn btn-dark-buy">Se connecter</button>
            <div class="mt-3">
                <a href="/auth/forgot-password" class="text-decoration-none" style="color: #4a2d7a;">Mot de passe oublié ?</a>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>